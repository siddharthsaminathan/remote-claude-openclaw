# ──────────────────────────────────────────────
# remote-claude-openclaw — per-laptop .env
# ──────────────────────────────────────────────
# Copy to .env and fill in your values.
# Each founder has their OWN .env on their OWN laptop.

# ── Founder Identity ──────────────────────────
FOUNDER_ID=siddharth
FOUNDER_NAME=Siddharth
FOUNDER_ROLE=CTO

# ── Paths ─────────────────────────────────────
LOCAL_REPO_PATH=/Users/siddharthsaminathan/Projects/Shanthibeta2
CLAUDE_CODE_COMMAND=claude

# ── Proxy / Model Routing ─────────────────────
# Proxy maps Claude aliases (opus/sonnet/haiku) to real models
ANTHROPIC_BASE_URL=http://localhost:8082
ANTHROPIC_AUTH_TOKEN=your-proxy-token-here
MAIN_MODEL_ALIAS=opus
CHEAP_MODEL_ALIAS=haiku

# ── Channel ───────────────────────────────────
# whatsapp (via OpenClaw)
CHANNEL=whatsapp

# ── Allowlist ─────────────────────────────────
# Comma-separated WhatsApp numbers that can reach this agent
ALLOWED_SENDERS=+919XXXXXXXXX

# ── OpenClaw ─────────────────────────────────
# OpenClaw gateway port
OPENCLAW_PORT=18789
# OpenClaw workspace (where safety CLAUDE.md lives)
OPENCLAW_WORKSPACE=~/.openclaw/workspace
