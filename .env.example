# ──────────────────────────────────────────────
# remote-claude-openclaw — per-laptop .env
# ──────────────────────────────────────────────
# Copy this to .env and fill in your values.
# Each founder has their OWN .env on their OWN laptop.

# ── Founder Identity ──────────────────────────
FOUNDER_ID=siddharth
FOUNDER_NAME=Siddharth
FOUNDER_ROLE=CTO

# ── Paths ─────────────────────────────────────
LOCAL_REPO_PATH=/Users/siddharthsaminathan/Projects/Shanthibeta2
CLAUDE_CODE_COMMAND=claude

# ── Proxy / Model Routing ─────────────────────
ANTHROPIC_BASE_URL=http://localhost:8082
ANTHROPIC_AUTH_TOKEN=your-proxy-token-here

# Use Claude aliases — the proxy maps them to real models
MAIN_MODEL_ALIAS=opus
CHEAP_MODEL_ALIAS=haiku

# ── Channel ───────────────────────────────────
# One of: whatsapp, telegram, slack
CHANNEL=whatsapp

# ── Allowlist ─────────────────────────────────
# Comma-separated sender IDs (phone numbers, telegram IDs, etc.)
ALLOWED_SENDERS=+919XXXXXXXXX

# ── Safety ────────────────────────────────────
# Never push without explicit "push" command
REQUIRE_PUSH_CONFIRMATION=true
# Never operate outside LOCAL_REPO_PATH
ENFORCE_REPO_SANDBOX=true
# Log every shell command
LOG_ALL_COMMANDS=true
